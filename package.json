{
  "name": "trainlens",
  "displayName": "TrainLens",
  "description": "A local training dashboard for VS Code.",
  "version": "0.0.1",
  "publisher": "trainlens",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "trainlens.openDashboard",
        "title": "TrainLens: Open Dashboard"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "prepublish": "npm run compile",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0",
    "vscode": "^1.1.37"
  }
}